if SHIELD_SOFLE_CHOC_PRO_DONGLE

# Max 16 characters
config ZMK_KEYBOARD_NAME
    default "Sofle Dongle"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config ZMK_SPLIT
    default y

# Two peripherals: the left and right halves.
config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
    default 2

# ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS (2) + desired BT output profiles (5).
config BT_MAX_CONN
    default 5

# Same number as BT_MAX_CONN.
config BT_MAX_PAIRED
    default 5

endif
